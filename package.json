{
  "name": "meyson-boilerplate",
  "description": "A comprehensive, opinionated company monorepo boilerplate",
  "license": "MIT",
  "author": "Meyson",
  "version": "0.0.1",
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:backend": "turbo build --filter=@mey/backend",
    "build:web": "turbo build --filter=@mey/web",
    "build:marketing": "turbo build --filter=@mey/marketing",
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=@mey/backend",
    "dev:web": "turbo dev --filter=@mey/web",
    "dev:marketing": "turbo dev --filter=@mey/marketing",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --fix",
    "typecheck": "turbo typecheck",
    "update-deps": "bunx npm-check-updates --workspaces",
    "update-deps:check": "bunx npm-check-updates --workspaces",
    "update-deps:upgrade": "bunx npm-check-updates -u --workspaces"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "turbo": "^2.5.6"
  }
}
